# --- CRM database ---
# Local default (if unset): sqlite:///.../banker_crm.sqlite3
# Phase 1 Postgres (Neon / Supabase), examples:
# CRM_DB_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require
CRM_DB_URL=

# --- Phase 2 API auth (uvicorn api.main:app) ---
CRM_API_USER=banker
CRM_API_PASSWORD=changeme
CRM_JWT_SECRET=dev-insecure-change-me
CRM_JWT_EXPIRE_MINUTES=720
# CRM_API_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Phase 3 file storage ---
# Local development:
CRM_STORAGE_BACKEND=local
CRM_LOCAL_STORAGE_PATH=./data/files

# Cloudflare R2 / AWS S3 (set CRM_STORAGE_BACKEND=s3):
CRM_S3_ENDPOINT_URL=
CRM_S3_REGION=auto
CRM_S3_BUCKET=
CRM_S3_ACCESS_KEY_ID=
CRM_S3_SECRET_ACCESS_KEY=
CRM_S3_PREFIX=banker-crm
CRM_S3_SIGNED_URL_TTL_SECONDS=3600
CRM_S3_MAX_UPLOAD_BYTES=20971520
CRM_MAX_EXPORT_BYTES=104857600
# CRM_ALLOWED_UPLOAD_TYPES=application/pdf,image/jpeg,image/png,text/plain

# --- CRM (existing) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Intel Terminal: LLM (pick one provider) ---
INTEL_LLM_PROVIDER=openai
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GEMINI_API_KEY=

# Model overrides (budget-friendly defaults)
INTEL_OPENAI_MODEL=gpt-4o-mini
INTEL_CLAUDE_MODEL=claude-3-5-haiku-latest
INTEL_GEMINI_MODEL=gemini-2.0-flash
INTEL_LLM_MAX_TOKENS=1024
INTEL_LLM_TEMPERATURE=0.2

# --- Intel Terminal: pipeline ---
INTEL_DB_PATH=
INTEL_FETCH_INTERVAL_MIN=60
INTEL_MAX_ARTICLES_PER_RUN=120
INTEL_DEDUP_THRESHOLD=0.88
INTEL_MIN_RELEVANCE=0.15
INTEL_VIETNAM_BOOST=0.12
INTEL_REUSE_SUMMARY_HOURS=48
INTEL_MAX_SUMMARIES_PER_RUN=12
INTEL_SUMMARY_MAX_BODY_CHARS=600
INTEL_NEWSPAPER_STORY_COUNT=15

# RSS SSL: only if feeds fail behind corporate proxy (insecure)
# INTEL_RSS_INSECURE_SSL=0

# Optional paid news API
INTEL_ENABLE_NEWSAPI=false
NEWSAPI_KEY=

# --- Phase 4 web (Next.js) ---
# NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

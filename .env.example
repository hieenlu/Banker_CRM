# --- CRM (existing) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Intel Terminal: LLM (pick one provider) ---
INTEL_LLM_PROVIDER=openai
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GEMINI_API_KEY=

# Model overrides (budget-friendly defaults)
INTEL_OPENAI_MODEL=gpt-4o-mini
INTEL_CLAUDE_MODEL=claude-3-5-haiku-latest
INTEL_GEMINI_MODEL=gemini-2.0-flash
INTEL_LLM_MAX_TOKENS=1024
INTEL_LLM_TEMPERATURE=0.2

# --- Intel Terminal: pipeline ---
INTEL_DB_PATH=
INTEL_FETCH_INTERVAL_MIN=60
INTEL_MAX_ARTICLES_PER_RUN=120
INTEL_DEDUP_THRESHOLD=0.88
INTEL_MIN_RELEVANCE=0.15
INTEL_VIETNAM_BOOST=0.12
INTEL_REUSE_SUMMARY_HOURS=48
INTEL_MAX_SUMMARIES_PER_RUN=12
INTEL_SUMMARY_MAX_BODY_CHARS=600
INTEL_NEWSPAPER_STORY_COUNT=15

# RSS SSL: only if feeds fail behind corporate proxy (insecure)
# INTEL_RSS_INSECURE_SSL=0

# Optional paid news API
INTEL_ENABLE_NEWSAPI=false
NEWSAPI_KEY=
